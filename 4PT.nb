Cell[TextData[{
 "This convenience fuction gives the angles ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Gamma]", "ab"], ",", " ", 
   SubscriptBox["\[Gamma]", "ac"], ",", " ", 
   SubscriptBox["\[Gamma]", "ad"], ",", " ", 
   SubscriptBox["\[CapitalPsi]", "c"], ",", " ", 
   SubscriptBox["\[CapitalPsi]", "d"]}]],ExpressionUUID->
  "d08e5e41-deaf-44c2-8a4e-acde8fae25e6"],
 " in terms of unit vectors. It is very useful to check the symmetries of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "abcd"], TraditionalForm]],ExpressionUUID->
  "46ed56f6-b122-4131-a9aa-79d5ef8bff49"],
 "."
}], "Text",
