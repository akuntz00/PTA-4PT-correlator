Cell[TextData[{
 "Results and formulas related to the paper ArXiv:??. We first directly give \
the full expression of the four-point function in terms of the angles ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "ab"], ",", " ", 
    SubscriptBox["\[Gamma]", "ac"], ",", " ", 
    SubscriptBox["\[Gamma]", "ad"], ",", " ", 
    SubscriptBox["\[CapitalPsi]", "c"], ",", " ", 
    SubscriptBox["\[CapitalPsi]", "d"], " "}], TraditionalForm]],
  ExpressionUUID->"091fd557-1b86-4da3-8646-852c900a0026"],
 "defined in the paper. We use the notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "b"], "=", 
    RowBox[{"cos", "(", 
     SubscriptBox["\[Gamma]", "ab"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"742d4c4b-3fb8-4a1b-9214-a8408968daf2"],
 ", etc."
}], "Text",
