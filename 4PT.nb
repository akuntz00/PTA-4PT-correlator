  3.981777937527541*^9}},ExpressionUUID->"7cadd0e0-40b9-4fdd-921e-\
0ffd236cd0b8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"vec2Angles", "[", 
    RowBox[{"p1_", ",", "p2_", ",", "p3_", ",", "p4_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c12t", "=", 
        RowBox[{"p1", ".", "p2"}]}], ",", " ", 
       RowBox[{"c13t", "=", 
        RowBox[{"p1", ".", "p3"}]}], ",", " ", 
       RowBox[{"c14t", "=", 
        RowBox[{"p1", ".", "p4"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
      "c12t", ",", " ", "c13t", ",", " ", "c14t", ",", "\[IndentingNewLine]", 
       " ", 
       RowBox[{
        RowBox[{"Sign", "[", 
         RowBox[{"p3", ".", 
          RowBox[{"Cross", "[", 
           RowBox[{"p1", ",", "p2"}], "]"}]}], "]"}], " ", 
        RowBox[{"ArcCos", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"p2", ".", "p3"}], "-", 
             RowBox[{"c12t", " ", "c13t"}]}], ")"}], "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             RowBox[{"c12t", "^", "2"}]}], "]"}]}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", 
            RowBox[{"c13t", "^", "2"}]}], "]"}]}], "]"}]}], ",", " ", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Sign", "[", 
         RowBox[{"p4", ".", 
          RowBox[{"Cross", "[", 
           RowBox[{"p1", ",", "p2"}], "]"}]}], "]"}], " ", 
        RowBox[{"ArcCos", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"p2", ".", "p4"}], "-", 
             RowBox[{"c12t", " ", "c14t"}]}], ")"}], "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"1", "-", 
             RowBox[{"c12t", "^", "2"}]}], "]"}]}], "/", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", 
            RowBox[{"c14t", "^", "2"}]}], "]"}]}], "]"}]}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"a153d6af-6168-44ce-9923-9c96855267e5"],

